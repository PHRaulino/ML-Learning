# Copie para .env e preencha. O .env NÃO é commitado.

# Postgres do fintrack
# Se o banco roda no Raspberry Pi na rede local, use o IP/hostname dele.
# Ex: PGHOST=raspberrypi.local   ou   PGHOST=192.168.0.42
PGHOST=localhost
PGPORT=5432
PGDATABASE=fintrack
PGUSER=fintrack
PGPASSWORD=changeme

# Connection string pronta para SQLAlchemy
DATABASE_URL=postgresql+psycopg2://fintrack:changeme@localhost:5432/fintrack
